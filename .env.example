# Supabase project that stores contact-form leads.
# Copy to .env.local for development, and set the same pair on Vercel.
#
# The anon key is public by design — the leads table grants it INSERT only
# (see supabase/leads.sql). The service role key is never used here.
#
# Not prefixed with NEXT_PUBLIC_: the form runs as a Server Action, so these
# stay on the server and out of the client bundle.

SUPABASE_URL=
SUPABASE_ANON_KEY=
