# Copy to .env.local for development, and set the same values on Vercel.

# Supabase project that stores contact-form leads.
#
# The anon key is public by design — the leads table grants it INSERT only
# (see supabase/leads.sql). The service role key is never used here.
#
# Not prefixed with NEXT_PUBLIC_: the form runs as a Server Action, so these
# stay on the server and out of the client bundle.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Salt for the hashed sender IP the contact form's rate limit groups by.
# Any long random string. Without it the stored hashes are reversible, since
# the IPv4 address space is small enough to brute-force.
#   openssl rand -hex 32
RATE_LIMIT_SALT=

# Absolute origin used for canonical URLs, Open Graph tags and the sitemap.
# Optional on Vercel: without it the project's production domain is used.
# Set it once a custom domain is in place.
SITE_URL=
